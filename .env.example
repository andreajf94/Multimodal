# RepoDesign Environment Variables

# Required for repo curation (GitHub API)
GITHUB_TOKEN=ghp_your_token_here

# Required for GRPO training via Tinker SDK
TINKER_API_KEY=tml-your_tinker_key_here

# Required for LLM calls (spec gen, teacher plans, LLM judge)
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Optional: legacy LLM providers (not used in current pipeline)
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here
